# ══════════════════════════════════════════════════════════════════
#  LABIADIO — Variáveis de Ambiente
#  Copie para .env.local e preencha os valores reais
#  NUNCA commite o .env.local no Git
# ══════════════════════════════════════════════════════════════════

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  BANCO DE DADOS
#  AGORA:   Supabase (supabase.com)
#  FUTURO:  Azure PostgreSQL Flexible Server
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# -- Supabase (atual) --
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# -- Azure PostgreSQL (futuro) --
# portal.azure.com → Azure Database for PostgreSQL → Flexible Server
# As migrations em supabase/migrations/ rodam sem alteração no Azure
# AZURE_POSTGRES_URL=postgresql://user:pass@servidor.postgres.database.azure.com:5432/labiadio?sslmode=require


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  AUTENTICAÇÃO
#  AGORA:   Supabase Auth + Azure AD OAuth (configurar no painel Supabase)
#  FUTURO:  NextAuth.js + Microsoft Entra ID direto
#           Ver: lib/auth/providers/nextauth-azure.ts
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# -- Azure App Registration (para ambos os modos) --
# portal.azure.com → Microsoft Entra ID → App registrations → New
# Permissões: openid, email, profile, User.Read
# Tipos de conta: "Accounts in this organizational directory only (PUCRS)"

# Modo atual (configurar no painel Supabase → Auth → Providers → Azure):
#   Cole o Client ID e Client Secret diretamente no painel — sem variáveis aqui

# Modo futuro (NextAuth direto):
# AUTH_SECRET=gere-com-openssl-rand-base64-32
# AUTH_MICROSOFT_ENTRA_ID_ID=client-id-do-app-azure
# AUTH_MICROSOFT_ENTRA_ID_SECRET=client-secret-do-app-azure
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/SEU-TENANT-ID/v2.0


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  INTELIGÊNCIA ARTIFICIAL
#  Troque AI_PROVIDER para mudar de provedor sem alterar código
#  Ver: lib/ai/index.ts
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Opções: anthropic | azure-openai | gemini
AI_PROVIDER=gemini

# -- Google Gemini (gratuito — recomendado para testes) --
# aistudio.google.com → Get API key
GOOGLE_API_KEY=AIza...
GOOGLE_AI_MODEL=gemini-1.5-flash

# -- Azure OpenAI (recomendado para produção PUCRS) --
# portal.azure.com → Azure OpenAI → Criar recurso → Deploy gpt-4o-mini
# AZURE_OPENAI_ENDPOINT=https://seu-recurso.openai.azure.com
# AZURE_OPENAI_KEY=sua-api-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-02-01

# -- Anthropic Claude --
# console.anthropic.com → API Keys
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  ARMAZENAMENTO DE ARQUIVOS (PDFs)
#  AGORA:   Supabase Storage (bucket 'docs') — sem variáveis extras
#  FUTURO:  Azure Blob Storage
#           Ver: lib/storage/index.ts
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# -- Azure Blob Storage (futuro) --
# portal.azure.com → Storage accounts → Criar conta → Container 'labiadio-docs'
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER=labiadio-docs


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  APP
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LABIADIO
