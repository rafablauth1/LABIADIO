# ══════════════════════════════════════════════════════════════
#  LABIADIO — Variáveis de Ambiente
#  Copie para .env.local e preencha os valores reais
#  NUNCA commite o .env.local no Git
# ══════════════════════════════════════════════════════════════

# ── BANCO DE DADOS (Supabase) ──────────────────────────────────
# Painel: supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# ── AUTENTICAÇÃO (Microsoft Entra ID / Office 365) ────────────
# Passos para configurar:
#   1. portal.azure.com → Microsoft Entra ID → App registrations → New
#   2. Redirect URI: https://SEU-PROJETO.supabase.co/auth/v1/callback
#   3. Permissões: openid, email, profile (delegadas)
#   4. Copie o Client ID e crie um Client Secret
#   5. Supabase Dashboard → Auth → Providers → Azure → habilitar
#      Cole o Azure Client ID e Client Secret no Supabase
# (nenhuma variável extra aqui — tudo configurado no painel Supabase)

# ── IA — SELECIONE O PROVEDOR ──────────────────────────────────
# Troque AI_PROVIDER para mudar de provedor sem alterar código.
# Opções: anthropic | azure-openai | gemini
AI_PROVIDER=gemini

# ── Opção A: Google Gemini (gratuito, recomendado para testes) ─
# Criar chave em: aistudio.google.com → Get API key
GOOGLE_API_KEY=AIza...
GOOGLE_AI_MODEL=gemini-1.5-flash

# ── Opção B: Azure OpenAI (recomendado para produção PUCRS) ────
# portal.azure.com → Azure OpenAI → Criar recurso → Deploy modelo
# Modelos recomendados: gpt-4o-mini (custo) ou gpt-4o (qualidade)
AZURE_OPENAI_ENDPOINT=https://seu-recurso.openai.azure.com
AZURE_OPENAI_KEY=sua-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Opção C: Anthropic Claude ──────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# ── APP ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LABIADIO
